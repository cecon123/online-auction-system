<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      spacing="24"
      styleClass="page">

    <padding>
        <Insets top="32" right="32" bottom="32" left="32"/>
    </padding>

    <VBox spacing="6">
        <Label text="Seller Dashboard" styleClass="page-title"/>
        <Label text="Manage your listings, track revenue, and review auction results."
               styleClass="page-subtitle"/>
    </VBox>

    <HBox spacing="16">
        <VBox styleClass="card" spacing="8" prefWidth="240">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>
            <Label text="SELLER BALANCE" styleClass="form-label"/>
            <Label text="\$12,800" styleClass="money-large"/>
            <Label text="Available to withdraw" styleClass="success-text"/>
        </VBox>

        <VBox styleClass="card" spacing="8" prefWidth="240">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>
            <Label text="ACTIVE LISTINGS" styleClass="form-label"/>
            <Label text="5" styleClass="stat-number"/>
            <Label text="Currently receiving bids" styleClass="page-subtitle"/>
        </VBox>

        <VBox styleClass="card" spacing="8" prefWidth="240">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>
            <Label text="TOTAL REVENUE" styleClass="form-label"/>
            <Label text="\$86,400" styleClass="money-large"/>
            <Label text="From completed auctions" styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <VBox styleClass="card" spacing="12">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <Label text="Recent Seller Activity" styleClass="section-title"/>
        <Label text="Vintage Omega Seamaster received a new bid: USD 3,450" styleClass="page-subtitle"/>
        <Label text="Leica M3 Rangefinder is still in draft status" styleClass="page-subtitle"/>
        <Label text="Classic Guitar auction finished successfully" styleClass="page-subtitle"/>
    </VBox>
</VBox>
