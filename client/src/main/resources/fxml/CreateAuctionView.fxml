<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.client.controller.CreateAuctionController"
      spacing="24"
      styleClass="page">

    <padding>
        <Insets top="32" right="32" bottom="32" left="32"/>
    </padding>

    <VBox spacing="6">
        <Label text="Create New Auction" styleClass="page-title"/>
        <Label text="Fill in the details below to list a new item in the Seller Center."
               styleClass="page-subtitle"/>
    </VBox>

    <VBox styleClass="card" spacing="18">
        <padding>
            <Insets top="24" right="24" bottom="24" left="24"/>
        </padding>

        <Label text="Item Details" styleClass="section-title"/>

        <GridPane hgap="16" vgap="14">
            <Label text="Product Name" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="productNameField" promptText="e.g. Vintage Rolex Submariner"
                       GridPane.rowIndex="1" GridPane.columnIndex="0"/>

            <Label text="Category" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <ComboBox fx:id="categoryComboBox" promptText="Select category"
                      GridPane.rowIndex="3" GridPane.columnIndex="0"/>

            <Label text="Starting Price" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <TextField fx:id="startingPriceField" promptText="0.00"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Start Time" styleClass="form-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="startTimeField" promptText="2026-05-04T09:00"
                       GridPane.rowIndex="5" GridPane.columnIndex="0"/>

            <Label text="End Time" styleClass="form-label" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
            <TextField fx:id="endTimeField" promptText="2026-05-05T09:00"
                       GridPane.rowIndex="5" GridPane.columnIndex="1"/>
        </GridPane>

        <Label text="Description" styleClass="form-label"/>
        <TextArea fx:id="descriptionArea"
                  promptText="Provide detailed information about the item..."
                  prefRowCount="5"/>

        <Label fx:id="messageLabel" styleClass="error-text"/>

        <HBox spacing="12">
            <Button text="Cancel" onAction="#handleCancel" styleClass="secondary-button"/>
            <Button text="Save Auction" onAction="#handleSaveAuction" styleClass="primary-button"/>
        </HBox>
    </VBox>
</VBox>
