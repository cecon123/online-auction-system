<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<BorderPane
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.auction.client.controller.AppShellController"
    styleClass="app-shell"
>

    <left>
        <fx:include source="components/Sidebar.fxml" />
    </left>

    <center>
        <BorderPane fx:id="contentRoot" id="contentRoot">
            <top>
                <VBox>
                    <!-- Disconnected Banner -->
                    <HBox fx:id="disconnectedBanner" spacing="12" alignment="CENTER" visible="false" managed="false" style="-fx-background-color: #ef4444; -fx-padding: 8 16;">
                        <org.kordamp.ikonli.javafx.FontIcon iconLiteral="mdi2w-wifi-off" iconSize="16" iconColor="white" />
                        <javafx.scene.control.Label text="Connection Lost. Attempting to reconnect..." style="-fx-text-fill: white; -fx-font-weight: bold;" />
                        <javafx.scene.layout.Region HBox.hgrow="ALWAYS" />
                        <javafx.scene.control.Button text="Retry Now" onAction="#handleRetryConnection" style="-fx-background-color: white; -fx-text-fill: #ef4444; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 4;" />
                    </HBox>
                    <fx:include source="components/TopBar.fxml" />
                </VBox>
            </top>
        </BorderPane>
    </center>

</BorderPane>
