<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      spacing="24"
      styleClass="page">

    <padding>
        <Insets top="32" right="32" bottom="32" left="32"/>
    </padding>

    <VBox spacing="6">
        <Label text="Admin Dashboard" styleClass="page-title"/>
        <Label text="System overview. Use Admin Panel to manage users and auctions."
               styleClass="page-subtitle"/>
    </VBox>

    <HBox spacing="16">
        <VBox styleClass="card" spacing="8" prefWidth="240">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>
            <Label text="TOTAL USERS" styleClass="form-label"/>
            <Label text="12,450" styleClass="stat-number"/>
            <Label text="+5.2%" styleClass="success-text"/>
        </VBox>

        <VBox styleClass="card" spacing="8" prefWidth="240">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>
            <Label text="TOTAL AUCTIONS" styleClass="form-label"/>
            <Label text="3,890" styleClass="stat-number"/>
            <Label text="+1.8%" styleClass="success-text"/>
        </VBox>

        <VBox styleClass="card" spacing="8" prefWidth="240">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>
            <Label text="RUNNING" styleClass="form-label"/>
            <Label text="1,204" styleClass="stat-number"/>
            <Label text="Live auctions" styleClass="page-subtitle"/>
        </VBox>

        <VBox styleClass="card" spacing="8" prefWidth="240">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>
            <Label text="FINISHED" styleClass="form-label"/>
            <Label text="2,686" styleClass="stat-number"/>
            <Label text="Completed auctions" styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <VBox styleClass="card" spacing="12">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <Label text="Admin Overview" styleClass="section-title"/>
        <Label text="12 auctions require review." styleClass="page-subtitle"/>
        <Label text="38 users are suspended." styleClass="page-subtitle"/>
        <Label text="Use Admin Panel from the sidebar to manage data." styleClass="page-subtitle"/>
    </VBox>
</VBox>
