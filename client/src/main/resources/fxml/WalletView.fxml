<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.client.controller.WalletController"
      spacing="24"
      styleClass="page">

    <padding>
        <Insets top="32" right="32" bottom="32" left="32"/>
    </padding>

    <VBox spacing="6">
        <Label text="Wallet" styleClass="page-title"/>
        <Label text="Deposit funds for bidding or withdraw revenue after successful auctions."
               styleClass="page-subtitle"/>
    </VBox>

    <VBox styleClass="card" spacing="14" prefWidth="420" maxWidth="520">
        <padding>
            <Insets top="24" right="24" bottom="24" left="24"/>
        </padding>

        <Label text="TOTAL BALANCE" styleClass="form-label"/>
        <Label fx:id="balanceLabel" styleClass="money-large"/>

        <HBox spacing="30">
            <VBox spacing="4">
                <Label text="AVAILABLE" styleClass="form-label-small"/>
                <Label fx:id="availableLabel" styleClass="money-medium"/>
            </VBox>
            <VBox spacing="4">
                <Label text="LOCKED / ESCROW" styleClass="form-label-small"/>
                <Label fx:id="lockedLabel" styleClass="money-medium-alt"/>
            </VBox>
        </HBox>

        <Label text="Amount" styleClass="form-label"/>
        <TextField fx:id="amountField" promptText="Enter amount"/>

        <HBox spacing="12">
            <Button text="Deposit" onAction="#handleDeposit" styleClass="primary-button"/>
            <Button text="Withdraw" onAction="#handleWithdraw" styleClass="secondary-button"/>
        </HBox>

        <Label fx:id="messageLabel" styleClass="page-subtitle" wrapText="true"/>
    </VBox>
</VBox>
