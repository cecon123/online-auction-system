<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<ScrollPane
    xmlns="http://javafx.com/javafx"
    fitToWidth="true"
    hbarPolicy="NEVER"
    vbarPolicy="AS_NEEDED"
    styleClass="page-scroll"
>

    <VBox spacing="24" styleClass="page">
        <padding>
            <Insets top="32" right="32" bottom="40" left="32" />
        </padding>

        <VBox spacing="6">
            <Label text="Bidder Dashboard" styleClass="page-title" />
            <Label
                text="Track your wallet, active bids, winning auctions, and recommended lots."
                styleClass="page-subtitle"
            />
        </VBox>

        <HBox spacing="16">
            <VBox styleClass="card" spacing="8" prefWidth="260">
                <padding>
                    <Insets top="18" right="18" bottom="18" left="18" />
                </padding>
                <Label text="WALLET BALANCE" styleClass="form-label" />
                <Label text="\$45,000" styleClass="money-large" />
                <Label text="Available to bid" styleClass="success-text" />
            </VBox>

            <VBox styleClass="card" spacing="8" prefWidth="260">
                <padding>
                    <Insets top="18" right="18" bottom="18" left="18" />
                </padding>
                <Label text="MY ACTIVE BIDS" styleClass="form-label" />
                <Label text="18" styleClass="stat-number" />
                <Label text="Across 5 categories" styleClass="page-subtitle" />
            </VBox>

            <VBox styleClass="card" spacing="8" prefWidth="260">
                <padding>
                    <Insets top="18" right="18" bottom="18" left="18" />
                </padding>
                <Label text="CURRENTLY WINNING" styleClass="form-label" />
                <Label text="7" styleClass="stat-number" />
                <Label text="Outbid on 2 items" styleClass="error-text" />
            </VBox>

            <VBox styleClass="card" spacing="8" prefWidth="260">
                <padding>
                    <Insets top="18" right="18" bottom="18" left="18" />
                </padding>
                <Label text="WATCHLIST" styleClass="form-label" />
                <Label text="5" styleClass="stat-number" />
                <Label
                    text="Following active lots"
                    styleClass="page-subtitle"
                />
            </VBox>
        </HBox>

        <HBox spacing="18">
            <VBox spacing="14" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label
                        text="Recommended Auctions"
                        styleClass="section-title"
                    />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="View All" styleClass="secondary-button" />
                </HBox>

                <HBox spacing="16">
                    <VBox styleClass="card" spacing="10" prefWidth="280">
                        <VBox styleClass="image-placeholder" prefHeight="140">
                            <Label
                                text="WATCH IMAGE"
                                styleClass="image-placeholder-text"
                            />
                        </VBox>

                        <VBox spacing="8">
                            <padding>
                                <Insets
                                    top="0"
                                    right="16"
                                    bottom="16"
                                    left="16"
                                />
                            </padding>

                            <Label text="LOT #4920" styleClass="form-label" />
                            <Label
                                text="Patek Philippe Nautilus"
                                styleClass="card-title"
                            />
                            <Label
                                text="Current Bid"
                                styleClass="page-subtitle"
                            />
                            <Label
                                text="\$125,000"
                                styleClass="money-large"
                            />
                        </VBox>
                    </VBox>

                    <VBox styleClass="card" spacing="10" prefWidth="280">
                        <VBox styleClass="image-placeholder" prefHeight="140">
                            <Label
                                text="CAR IMAGE"
                                styleClass="image-placeholder-text"
                            />
                        </VBox>

                        <VBox spacing="8">
                            <padding>
                                <Insets
                                    top="0"
                                    right="16"
                                    bottom="16"
                                    left="16"
                                />
                            </padding>

                            <Label text="LOT #4921" styleClass="form-label" />
                            <Label
                                text="1964 Aston Martin DB5"
                                styleClass="card-title"
                            />
                            <Label
                                text="Current Bid"
                                styleClass="page-subtitle"
                            />
                            <Label
                                text="\$850,000"
                                styleClass="money-large"
                            />
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="14" prefWidth="330">
                <Label text="Personal Activity" styleClass="section-title" />

                <VBox styleClass="card" spacing="12">
                    <padding>
                        <Insets top="18" right="18" bottom="18" left="18" />
                    </padding>

                    <Label
                        text="You are winning Patek Philippe Nautilus."
                        styleClass="success-text"
                    />
                    <Label
                        text="You were outbid on Aston Martin DB5."
                        styleClass="error-text"
                    />
                    <Label
                        text="Your last bid was &#36;32,000 on Untitled Composition II."
                        styleClass="page-subtitle"
                    />
                    <Label
                        text="Wallet balance is enough for 3 recommended lots."
                        styleClass="page-subtitle"
                    />
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
