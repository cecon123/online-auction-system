<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.auction.client.controller.RegisterController"
           styleClass="login-root">

    <fx:define>
        <ToggleGroup fx:id="roleGroup"/>
    </fx:define>

    <VBox styleClass="login-card" spacing="14" maxWidth="440">
        <padding>
            <Insets top="32" right="32" bottom="32" left="32"/>
        </padding>

        <Label text="⚖" styleClass="login-logo"/>
        <Label text="Create an Account" styleClass="login-title"/>
        <Label text="Join AuctionPro to start bidding or selling" styleClass="login-subtitle"/>

        <HBox spacing="8">
            <ToggleButton fx:id="bidderToggle"
                          text="BIDDER"
                          toggleGroup="$roleGroup"
                          maxWidth="Infinity"
                          HBox.hgrow="ALWAYS"/>
            <ToggleButton fx:id="sellerToggle"
                          text="SELLER"
                          toggleGroup="$roleGroup"
                          maxWidth="Infinity"
                          HBox.hgrow="ALWAYS"/>
        </HBox>

        <TextField fx:id="fullNameField" promptText="Full name"/>
        <TextField fx:id="usernameField" promptText="Username"/>
        <PasswordField fx:id="passwordField" promptText="Password"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm password"/>

        <Label fx:id="messageLabel" wrapText="true" styleClass="error-text"/>

        <Button text="REGISTER"
                onAction="#handleRegister"
                maxWidth="Infinity"
                styleClass="primary-button"/>

        <Button text="BACK TO LOGIN"
                onAction="#handleBackToLogin"
                maxWidth="Infinity"
                styleClass="secondary-button"/>
    </VBox>
</StackPane>
