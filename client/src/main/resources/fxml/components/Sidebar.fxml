<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.auction.client.controller.SidebarController"
    styleClass="sidebar"
    spacing="10"
    prefWidth="260"
>

    <padding>
        <Insets top="28" right="18" bottom="28" left="18" />
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <ImageView fitWidth="40" preserveRatio="true">
            <image>
                <Image url="@../../images/logo-image.png" />
            </image>
        </ImageView>
        <Label text="AuctionPro" styleClass="sidebar-title" />
    </HBox>
    <Label text="Premium Bidding" styleClass="sidebar-subtitle" />

    <Region prefHeight="32" />

    <Button
        fx:id="auctionsButton"
        onAction="#showAuctions"
        maxWidth="Infinity"
        styleClass="nav-button"
        text="Auctions"
    >
        <graphic>
            <FontIcon iconLiteral="mdi2g-gavel" iconSize="18" />
        </graphic>
    </Button>

    <Button
        fx:id="liveBiddingButton"
        onAction="#showLiveBidding"
        maxWidth="Infinity"
        styleClass="nav-button"
        text="Live Bidding"
    >
        <graphic>
            <FontIcon iconLiteral="mdi2t-timer-outline" iconSize="18" />
        </graphic>
    </Button>

    <Button
        fx:id="myBidsButton"
        onAction="#showMyBids"
        maxWidth="Infinity"
        styleClass="nav-button"
        text="My Bids"
    >
        <graphic>
            <FontIcon iconLiteral="mdi2h-history" iconSize="18" />
        </graphic>
    </Button>

    <Button
        fx:id="sellerCenterButton"
        onAction="#showSellerCenter"
        maxWidth="Infinity"
        styleClass="nav-button"
        text="Seller Center"
    >
        <graphic>
            <FontIcon iconLiteral="mdi2s-storefront-outline" iconSize="18" />
        </graphic>
    </Button>

    <Button
        fx:id="walletButton"
        onAction="#showWallet"
        maxWidth="Infinity"
        styleClass="nav-button"
        text="Wallet"
    >
        <graphic>
            <FontIcon iconLiteral="mdi2w-wallet-outline" iconSize="18" />
        </graphic>
    </Button>

    <Button
        fx:id="adminPanelButton"
        onAction="#showAdminPanel"
        maxWidth="Infinity"
        styleClass="nav-button"
        text="Admin Panel"
    >
        <graphic>
            <FontIcon iconLiteral="mdi2s-shield-check-outline" iconSize="18" />
        </graphic>
    </Button>

    <Region VBox.vgrow="ALWAYS" />

    <Button
        onAction="#logout"
        maxWidth="Infinity"
        styleClass="nav-button"
        text="Logout"
    >
        <graphic>
            <FontIcon iconLiteral="mdi2l-logout" iconSize="18" />
        </graphic>
    </Button>
</VBox>
