<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<HBox
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.auction.client.controller.TopBarController"
    styleClass="topbar"
    spacing="16"
    alignment="CENTER_LEFT"
>

    <padding>
        <Insets top="12" right="24" bottom="12" left="24" />
    </padding>

    <TextField promptText="Search auctions..." prefWidth="360" />

    <Region HBox.hgrow="ALWAYS" />

    <Button
        fx:id="placeBidButton"
        text="Place Bid"
        onAction="#handlePlaceBidShortcut"
        styleClass="primary-button"
    />

    <Button
        fx:id="walletButton"
        text="Wallet"
        onAction="#handleWalletShortcut"
        styleClass="secondary-button"
    />

    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="user-menu">
        <Label fx:id="avatarLabel" text="U" styleClass="avatar-label" />

        <VBox spacing="2">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label
                    fx:id="usernameLabel"
                    text="username"
                    styleClass="topbar-username"
                />
                <Label
                    fx:id="roleLabel"
                    text="BIDDER"
                    styleClass="role-badge"
                />
            </HBox>

            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label
                    fx:id="balanceCaptionLabel"
                    text="Balance:"
                    styleClass="topbar-muted"
                />
                <Label
                    fx:id="balanceLabel"
                    text="0"
                    styleClass="topbar-balance"
                />
            </HBox>
        </VBox>
    </HBox>
</HBox>
