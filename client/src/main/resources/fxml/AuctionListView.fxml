<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<VBox
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.auction.client.controller.AuctionListController"
    spacing="20"
    styleClass="page"
>

    <padding>
        <Insets top="28" right="32" bottom="32" left="32" />
    </padding>

    <VBox spacing="6">
        <Label text="Live Auctions" styleClass="page-title" />
        <Label
            text="Browse active and upcoming auction lots."
            styleClass="page-subtitle"
        />
    </VBox>

    <HBox spacing="12">
        <TextField promptText="Search auctions..." prefWidth="300" />
        <ComboBox promptText="All Categories" prefWidth="180" />
        <ComboBox promptText="Any Status" prefWidth="180" />
        <ComboBox promptText="Any Price Range" prefWidth="200" />
    </HBox>

    <TilePane hgap="16" vgap="16" prefColumns="3">
        <VBox styleClass="card" spacing="8" prefWidth="280">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18" />
            </padding>
            <Label text="Fine Art &amp; Antiques" styleClass="form-label" />
            <Label
                text="19th Century Gold Pocket Watch"
                styleClass="card-title"
            />
            <Label text="Current Bid" styleClass="page-subtitle" />
            <Label text="\$12,500" styleClass="money-large" />
            <Button
                text="View Detail"
                onAction="#openAuctionDetail"
                styleClass="secondary-button"
            />
            <Button
                text="Live Bid"
                onAction="#openLiveBidding"
                styleClass="primary-button"
            />
        </VBox>

        <VBox styleClass="card" spacing="8" prefWidth="280">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18" />
            </padding>
            <Label text="Classic Vehicles" styleClass="form-label" />
            <Label text="1965 Vintage Roadster" styleClass="card-title" />
            <Label text="Winning Bid" styleClass="page-subtitle" />
            <Label text="\$85,000" styleClass="money-large" />
            <Button
                text="View Detail"
                onAction="#openAuctionDetail"
                styleClass="secondary-button"
            />
            <Button
                text="Live Bid"
                onAction="#openLiveBidding"
                styleClass="primary-button"
            />
        </VBox>

        <VBox styleClass="card" spacing="8" prefWidth="280">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18" />
            </padding>
            <Label text="Jewelry &amp; Watches" styleClass="form-label" />
            <Label text="Kashmir Sapphire Ring 12ct" styleClass="card-title" />
            <Label text="Current Bid" styleClass="page-subtitle" />
            <Label text="\$145,000" styleClass="money-large" />
            <Button
                text="View Detail"
                onAction="#openAuctionDetail"
                styleClass="secondary-button"
            />
            <Button
                text="Live Bid"
                onAction="#openLiveBidding"
                styleClass="primary-button"
            />
        </VBox>
    </TilePane>
</VBox>
