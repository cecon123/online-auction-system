<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<VBox
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.auction.client.controller.AuctionListController"
    spacing="20"
    styleClass="page"
>

    <padding>
        <Insets top="28" right="32" bottom="32" left="32" />
    </padding>

    <VBox spacing="6">
        <Label text="Live Auctions" styleClass="page-title" />
        <Label
            text="Browse active and upcoming auction lots."
            styleClass="page-subtitle"
        />
    </VBox>

    <HBox spacing="12">
        <TextField promptText="Search auctions..." prefWidth="300" />
        <ComboBox promptText="All Categories" prefWidth="180" />
        <ComboBox promptText="Any Status" prefWidth="180" />
        <ComboBox promptText="Any Price Range" prefWidth="200" />
    </HBox>

    <TilePane fx:id="auctionContainer" hgap="16" vgap="16" prefColumns="3">
        <!-- Dynamically populated from controller -->
    </TilePane>
</VBox>
