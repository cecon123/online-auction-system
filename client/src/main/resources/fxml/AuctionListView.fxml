<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.auction.client.controller.AuctionListController"
    spacing="24"
    styleClass="page"
>
    <padding>
        <Insets top="28" right="32" bottom="32" left="32" />
    </padding>

    <VBox spacing="8">
        <Label text="Live Auctions" styleClass="page-title" />
        <Label
            text="Discover and bid on exclusive items from around the world."
            styleClass="page-subtitle"
        />
    </VBox>

    <HBox spacing="16" alignment="CENTER_LEFT" styleClass="filter-bar">
        <TextField fx:id="searchField" promptText="Search auctions by name..." prefWidth="350" styleClass="search-field" />
        <ComboBox fx:id="categoryFilter" promptText="All Categories" prefWidth="180" />
        <ComboBox fx:id="statusFilter" promptText="Active Status" prefWidth="180" />
        <HBox HBox.hgrow="ALWAYS" />
        <Button onAction="#initialize" styleClass="secondary-button" text="Refresh">
            <graphic>
                <FontIcon iconLiteral="mdi2r-refresh" iconSize="16" />
            </graphic>
        </Button>
    </HBox>

    <javafx.scene.control.ScrollPane 
        fitToWidth="true" 
        styleClass="content-scroll-pane" 
        VBox.vgrow="ALWAYS"
    >
        <content>
            <TilePane 
                fx:id="auctionContainer" 
                hgap="20" 
                vgap="24" 
                prefColumns="3" 
                alignment="TOP_LEFT"
                style="-fx-background-color: transparent;"
            >
                <padding>
                    <Insets top="4" right="4" bottom="20" left="4" />
                </padding>
            </TilePane>
        </content>
    </javafx.scene.control.ScrollPane>
</VBox>
